NODE_ENV=development
PORT=5000

# Client Configuration
CLIENT_URL=http://localhost:5173

# Database
# Example: mongodb://localhost:27017/msrcasc-connect or MongoDB Atlas string
MONGO_URI=your_secure_mongodb_connection_string

# Authentication Secrets
# DO NOT track in version control! Rotate securely in production.
# Recommended: generate using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=your_super_secret_jwt_key_that_is_long_and_random
JWT_EXPIRE=30d

# Email Configuration (SMTP)
# Used for password resets and email verification
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your_smtp_user
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@msrcasc-connect.com
FROM_NAME="MSRCASC Connect System"

# Integration API Keys
# Must not be committed or logged to the console
OPENAI_API_KEY=your_openai_api_key_here
